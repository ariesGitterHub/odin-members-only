<form class="edit-profile-admin-form" action="/app/???" method="POST">
  <label class="capitalize" for="first-name-edit-profile-admin">
    first name (fname)
  </label>
  <input
    id="first-name-edit-profile-admin"
    class="bold"
    type="text"
    name="first_name"
    required
  />
  <label class="capitalize" for="last-name-edit-profile-admin">
    last name (lname)
  </label>
  <input
    id="last-name-edit-profile-admin"
    class="bold"
    type="text"
    name="last_name"
    required
  />
  <%# if (currentUser && currentUser.permission_status !== "admin") { %> 
  <div class="element-container-profile-block">
    <div class="element-container-col-center">
      <label for="permission-status-edit-profile-admin">
        permission status
      </label>
      <select
        id="permission-status-edit-profile-admin"
        class="lowercase bold"
        name="permission_status"
        required
      >
        <option value="guest">guest</option>
        <option value="member">member</option>
        <option value="admin">admin</option>
      </select>
    </div>
    <div class="element-container-col-center">
      <label for="verified-by-admin-edit-profile-admin"> admin verified </label>
      <select
        id="verified-by-admin-edit-profile-admin"
        class="lowercase bold"
        name="verified_by_admin"
      >
        <option value="true">true</option>
        <option value="false">false</option>
      </select>
    </div>
    <div class="element-container-col-center">
      <label for="upgrade-request-edit-profile-admin"> member request </label>
      <select
        id="upgrade-request-edit-profile-admin"
        class="lowercase bold"
        name="upgrade_request"
      >
        <option value="true">true</option>
        <option value="false">false</option>
      </select>
    </div>
    <div class="element-container-col-center">
      <label for="is-active-edit-profile-admin"> active status </label>
      <select
        id="is-active-edit-profile-admin"
        class="lowercase bold"
        name="is_active"
      >
        <option value="true">true</option>
        <option value="false">false</option>
      </select>
    </div>
  </div>
  <%# } %>
  <label class="capitalize" for="email-edit-profile-admin">
    email address
  </label>
  <input
    id="email-edit-profile-admin"
    class="lowercase bold"
    type="email"
    name="email"
    required
  />
  <div class="element-container-row-space-between">
    <div class="element-container-col">
      <label class="capitalize" for="phone-edit-profile-admin"> phone </label>
      <input
        id="phone-edit-profile-admin"
        class="bold"
        type="phone"
        name="phone"
      />
    </div>
    <div class="element-container-col">
      <label class="capitalize" for="birthdate-edit-profile-admin">
        birthdate
      </label>
      <input
        id="birthdate-edit-profile-admin"
        class="bold"
        type="date"
        name="birthdate"
        required
      />
    </div>
  </div>
  <label for="password-edit-profile-admin"> password </label>
  <input
    id="password-edit-profile-admin"
    type="password"
    name="password"
    placeholder="select a password"
    required
  />
  <label for="confirm-password-edit-profile-admin"> confirm password </label>
  <input
    id="confirm-password-edit-profile-admin"
    type="password"
    name="confirm_password"
    placeholder="re-enter chosen password"
    required
  />
  <label class="capitalize" for="street-address-edit-profile-admin">
    street address
  </label>
  <input
    id="street-address-edit-profile-admin"
    class="bold"
    type="text"
    name="street_address"
  />
  <div class="element-container-row-space-between">
    <div class="element-container-col">
      <label class="capitalize" for="apt-unit-edit-profile-admin">
        apt/unit
      </label>
      <input
        id="apt-unit-edit-profile-admin"
        class="bold"
        type="text"
        name="apt_unit"
      />
    </div>
    <div class="element-container-col">
      <label class="capitalize" for="us-state-edit-profile-admin">
        state
      </label>
      <select id="us-state-edit-profile-admin" name="us_state">
        <option value="AL">Alabama</option>
        <option value="AK">Alaska</option>
        <option value="AZ">Arizona</option>
        <option value="AR">Arkansas</option>
        <option value="CA">California</option>
        <option value="CO">Colorado</option>
        <option value="CT">Connecticut</option>
        <option value="DE">Delaware</option>
        <option value="DC">Washington, DC</option>
        <option value="FL">Florida</option>
        <option value="GA">Georgia</option>
        <option value="HI">Hawaii</option>
        <option value="ID">Idaho</option>
        <option value="IL">Illinois</option>
        <option value="IN">Indiana</option>
        <option value="IA">Iowa</option>
        <option value="KS">Kansas</option>
        <option value="KY">Kentucky</option>
        <option value="LA">Louisiana</option>
        <option value="ME">Maine</option>
        <option value="MD">Maryland</option>
        <option value="MA">Massachusetts</option>
        <option value="MI">Michigan</option>
        <option value="MN">Minnesota</option>
        <option value="MS">Mississippi</option>
        <option value="MO">Missouri</option>
        <option value="MT">Montana</option>
        <option value="NE">Nebraska</option>
        <option value="NV">Nevada</option>
        <option value="NH">New Hampshire</option>
        <option value="NJ">New Jersey</option>
        <option value="NM">New Mexico</option>
        <option value="NY">New York</option>
        <option value="NC">North Carolina</option>
        <option value="ND">North Dakota</option>
        <option value="OH">Ohio</option>
        <option value="OK">Oklahoma</option>
        <option value="OR">Oregon</option>
        <option value="PA" selected>Pennsylvania</option>
        <option value="RI">Rhode Island</option>
        <option value="SC">South Carolina</option>
        <option value="SD">South Dakota</option>
        <option value="TN">Tennessee</option>
        <option value="TX">Texas</option>
        <option value="UT">Utah</option>
        <option value="VT">Vermont</option>
        <option value="VA">Virginia</option>
        <option value="WA">Washington</option>
        <option value="WV">West Virginia</option>
        <option value="WI">Wisconsin</option>
        <option value="WY">Wyoming</option>
      </select>
    </div>
  </div>
  <div class="element-container-row-space-between">
    <div class="element-container-col">
      <label class="capitalize" for="city-edit-profile-admin"> city </label>
      <input
        id="city-edit-profile-admin"
        class="bold"
        type="text"
        name="city"
      />
    </div>
    <div class="element-container-col">
      <label class="capitalize" for="zip-code-edit-profile-admin"> zip </label>
      <input
        id="zip-code-edit-profile-admin"
        class="bold"
        type="text"
        name="zip_code"
      />
    </div>
  </div>
  <div class="element-container-row-space-between">
    <div class="element-container-col">
      <label for="avatar-type-edit-profile-admin"> avatar </label>
      <input
        id="avatar-type-edit-profile-admin"
        class="emoji lowercase bold"
        type="text"
        name="avatar_type"
      />
    </div>
    <div class="element-container-col">
      <label for="avatar-color-fg-edit-profile-admin"> colorFG </label>
      <input
        id="avatar-color-fg-edit-profile-admin"
        class="lowercase bold"
        type="text"
        name="avatar_color_fg"
      />
    </div>
    <div class="element-container-col">
      <label for="avatar-color-bg-top-edit-profile-admin"> colorBG↑ </label>
      <input
        id="avatar-color-bg-top-edit-profile-admin"
        class="lowercase bold"
        type="text"
        name="avatar_color_bg_top"
      />
    </div>
    <div class="element-container-col">
      <label for="avatar-color-bg-bottom-edit-profile-admin"> colorBG↓ </label>
      <input
        id="avatar-color-bg-bottom-edit-profile-admin"
        class="lowercase bold"
        type="text"
        name="avatar_color_bg_bottom"
      />
    </div>
  </div>
  <label class="capitalize" for="notes-edit-profile-admin"> notes </label>
  <textarea
    id="notes-edit-profile-admin"
    class="bold"
    type="text"
    name="notes"
  ></textarea>
  <div class="button-container">
    <button class="wide-button" type="submit">submit profile changes</button>
  </div>
</form>
