<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
  </head>
  <body>
    <%- include('./partials/header.ejs') %>
    <main>
      <div class="page-title-off-card uppercase">
        <h1>your profile</h1>
      </div>
      <div class="card">
        <% if (!currentUser) { %> 
        <p>No current user is logged in.</p>
        <% } else { %>
            <div class="profile-data">
              <div class="avatar-image-container-wide">
                <div 
                  class="avatar-image-circle avatar-circle-large" 
                  style="
                    --avatar-color-fg: <%= currentUser.avatar_color_fg || 'var(--off-black)' %>;
                    --avatar-color-bg-top: <%= currentUser.avatar_color_bg_top || 'var(--off-white)' %>;
                    --avatar-color-bg-bottom: <%= currentUser.avatar_color_bg_bottom || 'var(--off-gray)' %>;
                  ">
                  <span class="emoji avatar-emoji-large-size" role="img" aria-label="avatar image">
                    <!-- 🐈‍⬛ -->
                    <%= currentUser.avatarLetter %>
                    <%#= currentUser.avatar_type %>
                  </span>
                </div>            
            </div>
              <dl class="profile-data-dl">
                <div>
                  <dt class="capitalize">name</dt>
                  <dd class="capitalize bold"><%= currentUser.first_name %> <%= currentUser.last_name %></dd>
                </div>
                <div>
                  <dt class="capitalize">status</dt>
                  <dd class="bold"><%= currentUser.permission_status %></dd>
                </div>
                <div>
                  <dt class="capitalize">email</dt>
                  <dd class="bold"><%= currentUser.email%></dd>
                </div>
                <div>
                  <dt class="capitalize">phone</dt>
                  <dd class="bold"><%= currentUser.phone || "n/a" %></dd>
                </div>
                <div>
                  <dt class="capitalize">birthdate</dt>
                  <dd class="bold"><%= currentUser.formattedBirthdate %> (age: <%= currentUser.age %>)</dd>
                </div>
                <div>
                  <dt class="capitalize">street</dt>
                  <dd class="bold"><%= currentUser.street_address || "n/a" %></dd>
                </div>
                <div>
                  <dt class="capitalize">apt/unit</dt>
                  <dd class="bold"><%= currentUser.apt_unit || "n/a" %></dd>
                </div>
                <div>
                  <dt class="capitalize">city</dt>
                  <dd class="bold"><%= currentUser.city || "n/a" %></dd>
                </div>
                <div>
                  <dt class="capitalize">state</dt>
                  <dd class="bold"><%= currentUser.us_state || "n/a" %></dd>
                </div>
                <div>
                  <dt class="capitalize">zip code</dt>
                  <dd class="bold"><%= currentUser.zip_code || "n/a" %></dd>
                </div>
              </dl>
              <div class="button-container-col">
                <% if (currentUser.permission_status !== "admin") { %>
                  <a class="fake-button wide-button" href="/app/delete">delete account</a> 
                  <span class="ui-message-warning uppercase">deletion of account is permanent.</span>                
                <% } %>
                <!-- NOTE - below should be hidden if user has member status! -->
                <% if (currentUser.permission_status === "guest" && currentUser.member_request === false) { %>
                  <!-- <button class="wide-button">upgrade to member</button> -->
                  <!-- <button class="wide-button" 
                  onclick="openModal('modal-become-member', 'modal-title-become-member')">
                    upgrade to member
                  </button> -->
                  <button 
                    class="wide-button open-modal-btn" 
                    data-section="modal-become-member" 
                    data-title="modal-title-become-member">
                    upgrade to member
                  </button>
                <% } %>
                <% if (currentUser.permission_status !== "guest") { %>
                <a class="fake-button wide-button" href="/app/member-directory">member directory</a>
                <% } %>
                <!-- Below - a link or button????? -->
                <!-- <a class="fake-button wide-button" href="/app/update-profile">update profile</a> -->
                <!-- <button class="wide-button" onclick="openModal('modal-edit-profile-user', 'modal-title-edit-profile-user')">
                    update your profile
                  </button> -->
                <button 
                  class="wide-button open-modal-btn" 
                  data-section="modal-edit-profile-user"
                  data-title="modal-title-edit-profile-user"
                  >
                    update your profile
                  </button>
                <!-- <a class="fake-button wide-button" href="/app/change-avatar">change avatar</a> -->
                <!-- <button class="wide-button" onclick="openModal('modal-change-avatar', 'modal-title-change-avatar')">
                  change this avatar
                </button> -->
                <!-- <button 
                  class="wide-button open-modal-btn" 
                  data-section="modal-change-avatar"
                  data-title="modal-title-change-avatar"
                  >
                  change this avatar
                </button> -->
                <button 
                  class="wide-button edit-change-avatar-button" 
                  data-section="modal-change-avatar-user"
                  data-title="modal-title-change-avatar-user"
                  data-user-id="<%= currentUser.id %>"
                  >
                  change this avatar
                </button>
              </div>
            </div>
          <% } %>
        </div>

        </div>

        </div>
      </div>
    </main>
    <%- include('./partials/modal-root.ejs') %>
    <%- include('./partials/footer.ejs') %>
  </body>
</html>
