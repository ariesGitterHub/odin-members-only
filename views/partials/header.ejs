<header class="sticky-header">
  <nav class="nav-bar" aria-label="user menu">
    <% if (currentUser && currentUser.permission_status === "admin") { %>
    <a class="fake-button nav-button" href="/app/admin">
      <span class="emoji emoji-nav-size" role="img" aria-label="admin's overview">
      ⚙
      </span>
    </a>
    <% } %>
    <a class="fake-button nav-button" href="/app/info">
      <span class="emoji emoji-nav-size" role="img" aria-label="this site's info">
        ℹ
      </span>
    </a>
      <button 
        class="fake-button nav-button new-post-button"
        data-section="modal-new-post"
        data-title="modal-title-new-post"
        >
        <span class="emoji emoji-nav-size" role="img" aria-label="create a new post">
          ✍🏼
        </span>
    </button>
    <a class="fake-button nav-button" href="/app/message-boards">
      <span class="emoji emoji-nav-size" role="img" aria-label="message board link">
      💬
      </span>
    </a>
    </a>
    <% if (currentUser) { %>
    <a class="fake-button nav-button" href="/app/your-profile">
      <span class="emoji emoji-nav-size" role="img" aria-label="avatar image and link to your profile">
        <%= currentUser.avatarLetter %>
      </span>
    </a>
    <% } %>
    <form action="/app/log-out" method="POST">
      <button class="fake-button nav-button" type="submit">
        <span class="emoji emoji-nav-size" role="img" aria-label="log out">
          📴
        </span>
      </button>
    </form>
  </nav>
  <% if (currentUser) { %>
  <div class="logged-in-bar uppercase"><p>logged in as "<%= currentUser.email %>" (<%= currentUser.permission_status %>)</p></div>
  <% } %>
</header>
