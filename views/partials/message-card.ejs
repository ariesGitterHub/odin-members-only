<div class="message-card">
  <div class="message-header">
    <!-- <div 
      class="avatar-image-container circle avatar-circle-small" 
      style="
        --avatar-color-fg: <%#= message.avatar_color_fg || 'var(--off-black)' %>;
        --avatar-color-bg-top: <%#= message.avatar_color_bg_top || 'var(--off-white)' %>;
        --avatar-color-bg-bottom: <%#= message.avatar_color_bg_bottom || 'var(--off-gray)' %>;
      ">
      <span class="emoji avatar-emoji-small-size" role="img" aria-label="avatar image">
        <%#= message.avatarLetter %>
      </span>
    </div> -->

    <div class="margin-right">
      <div 
        class="avatar-container avatar-container-size-small avatar-background circle " 
        style="
          --avatar-color-fg: <%= message.avatar_color_fg || 'var(--off-black)' %>;
          --avatar-color-bg-top: <%= message.avatar_color_bg_top || 'var(--off-white)' %>;
          --avatar-color-bg-bottom: <%= message.avatar_color_bg_bottom || 'var(--off-gray)' %>;
        ">
        <span class="emoji emoji-size-small" role="image" aria-label="avatar image">
          <%#= message.avatarLetter %>
          <%= message.avatar_type %>
        </span>
      </div>          
    </div>
    <div class="message-name-and-title">
      <p class="message-name bold"><%= message.first_name %> <%= message.last_name %></p>
      <p class="message-title bold"><%= message.title %></p>
    </div>
  </div>
  <div class="message-details uppercase">
    <span>created: <%= new Date(message.created_at).toLocaleDateString() %></span>
    <!-- <span>chars: <%#= message.body.length %>/700</span>     -->
    <span>expires: <%= new Date(message.expires_at).toLocaleDateString() %></span>   
    <!-- <span>likes: <%= message.like_count %></span>  -->
  </div>
  <div class="message-body">
    <p>
      <!-- <span class="emoji">🗨️</span>  -->
      <%= message.body %>
    </p>
  </div>
  <div class="message-footer">
  <%# if (currentUser) { %>
    
      <div class="message-button-container">
        <!-- <button class="message-button" type="button">Edit</button> -->
        <!-- BELOW NEEDS DELETE ACCESS TO THE PERSON WHO WROTE IT -->
        <!-- <%# if (message && message.permission_status === "admin") { %> -->
        <%# if (message && currentUser && currentUser.permission_status === "admin") { %>
         <button class="button-default message-button <%= canPerformHasRole(currentUser, 'sticky-message', message) ? '' : 'hidden' %>" type="button"><span class="emoji">📌</span></button>
        <%# } %>
        <!-- <%# if (message && (message.user_id === currentUser.id || message.permission_status === "admin")) { %> -->
        <%# if (message && currentUser && (currentUser.permission_status === "admin" || message.user_id === currentUser.id)) { %>
         <!-- <button 
          class="button-default message-button delete-button <%#= canPerformHasRole(currentUser, 'delete-message', message) ? '' : 'hidden' %>" type="button"
          data-section="modal-warning-message-deletion"
          data-title="modal-title-warning-message-deletion"
          data-target-id="<%#= message.id %>"
          data-action="/app/delete-message"
        >
          <span class="emoji">🗑</span>
        </button> -->
         <button 
          class="button-default message-button delete-button <%= canPerformHasRole(currentUser, 'delete-message', message) ? '' : 'hidden' %>" type="button"
          data-section="modal-warning-message-deletion"
          data-title="modal-title-warning-message-deletion"
          data-target-id="<%= message.id %>"
          data-slug="<%= topic.slug %>"
          data-action="/app/message-boards/delete-message"
        >
          <span class="emoji">🗑</span>
        </button>
        <%# } %>
        <!-- TODO - BELOW NEEDS TO BE HIDDEN TO THE PERSON WHO WROTE IT **OR** DOES IT??????-->
        <button class="button-default message-button" type="button"><span class="emoji">↩</span>(<%= message.reply_count %>)</button>
        
        <form action="/messages/<%= message.id %>/like" method="POST">
        
        <button class="button-default message-button" type="submit"><span class="emoji">❤</span>(<%= message.like_count %>)</button>
      </form>          
      </div>

    <%# } %>
  </div>
</div>
