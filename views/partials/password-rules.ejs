<div class="password-rules-container">
  <h3><span class="emoji">🔐</span>Passwords must contain:</h3>
  <p><span class="emoji">↔</span> at least 16 characters</p>
  <p><span class="emoji">🔡</span> at least one lowercase letter</p>
  <p><span class="emoji">🔠</span> at least one uppercase letter</p>
  <p><span class="emoji">🔢</span> at least one number</p>
  <p>
    <span class="emoji">🔣</span> at least one special character: @$!%*?&
  </p>
</div>
