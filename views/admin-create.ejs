<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
  </head>
  <body>
    <%- include('./partials/header.ejs') %>
    <main>
      <div class="page-title-off-card uppercase">
        <h1>create new user</h1>
      </div>
      <div class="card">
        <form action="/app/???" method="POST">
            <label class="capitalize" for="first-name-admin-create-page">
                first name (fname)
            </label>
            <input
                id="first-name-admin-create-page"
                class="bold"
                type="text"
                name="first_name"
                required
            />
            <label class="capitalize" for="last-name-admin-create-page">
                last name (lname)
            </label>
            <input
                id="last-name-admin-create-page"
                class="bold"
                type="text"
                name="last_name"
                required
            />
            <%# if (currentUser && currentUser.permission_status !== "admin") { %> 
            <div class="element-container-profile-block">
                <div class="element-container-col-default">
                <label for="permission-status-admin-create-page">
                    permission status
                </label>
                <select
                    id="permission-status-admin-create-page"
                    class="lowercase bold"
                    name="permission_status"
                    required
                >
                    <option value="guest" selected>guest</option>
                    <option value="member">member</option>
                    <option value="admin">admin</option>
                </select>
                </div>
                <div class="element-container-col-default">
                <label for="verified-by-admin-admin-create-page"> admin verified </label>
                <select
                    id="verified-by-admin-admin-create-page"
                    class="lowercase bold"
                    name="verified_by_admin"
                >
                    <option value="true">true</option>
                    <option value="false" selected>false</option>
                </select>
                </div>
                <div class="element-container-col-default">
                <label for="member-request-admin-create-page"> member request </label>
                <select
                    id="member-request-admin-create-page"
                    class="lowercase bold"
                    name="member_request"
                >
                    <option value="true">true</option>
                    <option value="false" selected>false</option>
                </select>
                </div>
                <div class="element-container-col-default">
                <label for="is-active-admin-create-page"> active status </label>
                <select
                    id="is-active-admin-create-page"
                    class="lowercase bold"
                    name="is_active"
                >
                    <option value="true" selected>true</option>
                    <option value="false">false</option>
                </select>
                </div>
            </div>
            <%# } %>
            <label class="capitalize" for="email-admin-create-page">
                email address
            </label>
            <input
                id="email-admin-create-page"
                class="lowercase bold"
                type="email"
                name="email"
                required
            />
            <div class="element-container-row-space-between">
                <div class="element-container-col-start-center">
                <label class="capitalize" for="phone-admin-create-page"> phone </label>
                <input
                    id="phone-admin-create-page"
                    class="bold"
                    type="phone"
                    name="phone"
                />
                </div>
                <div class="element-container-col-start-center">
                <label class="capitalize" for="birthdate-admin-create-page">
                    birthdate
                </label>
                <input
                    id="birthdate-admin-create-page"
                    class="bold"
                    type="date"
                    name="birthdate"
                    required
                />
                </div>
            </div>
            <label for="password-admin-create-page"> password </label>
            <input
                id="password-admin-create-page"
                type="password"
                name="password"
                placeholder="select a password"
                required
            />
            <label for="confirm-password-admin-create-page"> confirm password </label>
            <input
                id="confirm-password-admin-create-page"
                type="password"
                name="confirm_password"
                placeholder="re-enter chosen password"
                required
            />
            <label class="capitalize" for="street-address-admin-create-page">
                street address
            </label>
            <input
                id="street-address-admin-create-page"
                class="bold"
                type="text"
                name="street_address"
            />
            <div class="element-container-row-space-between">
                <div class="element-container-col-start-center">
                <label class="capitalize" for="apt-unit-admin-create-page">
                    apt/unit
                </label>
                <input
                    id="apt-unit-admin-create-page"
                    class="bold"
                    type="text"
                    name="apt_unit"
                />
                </div>
                <div class="element-container-col-start-center">
                <label class="capitalize" for="us-state-admin-create-page">
                    state
                </label>
                <select id="us-state-admin-create-page" name="us_state">
                    <option value="AL">Alabama</option>
                    <option value="AK">Alaska</option>
                    <option value="AZ">Arizona</option>
                    <option value="AR">Arkansas</option>
                    <option value="CA">California</option>
                    <option value="CO">Colorado</option>
                    <option value="CT">Connecticut</option>
                    <option value="DE">Delaware</option>
                    <option value="DC">Washington, DC</option>
                    <option value="FL">Florida</option>
                    <option value="GA">Georgia</option>
                    <option value="HI">Hawaii</option>
                    <option value="ID">Idaho</option>
                    <option value="IL">Illinois</option>
                    <option value="IN">Indiana</option>
                    <option value="IA">Iowa</option>
                    <option value="KS">Kansas</option>
                    <option value="KY">Kentucky</option>
                    <option value="LA">Louisiana</option>
                    <option value="ME">Maine</option>
                    <option value="MD">Maryland</option>
                    <option value="MA">Massachusetts</option>
                    <option value="MI">Michigan</option>
                    <option value="MN">Minnesota</option>
                    <option value="MS">Mississippi</option>
                    <option value="MO">Missouri</option>
                    <option value="MT">Montana</option>
                    <option value="NE">Nebraska</option>
                    <option value="NV">Nevada</option>
                    <option value="NH">New Hampshire</option>
                    <option value="NJ">New Jersey</option>
                    <option value="NM">New Mexico</option>
                    <option value="NY">New York</option>
                    <option value="NC">North Carolina</option>
                    <option value="ND">North Dakota</option>
                    <option value="OH">Ohio</option>
                    <option value="OK">Oklahoma</option>
                    <option value="OR">Oregon</option>
                    <option value="PA" selected>Pennsylvania</option>
                    <option value="RI">Rhode Island</option>
                    <option value="SC">South Carolina</option>
                    <option value="SD">South Dakota</option>
                    <option value="TN">Tennessee</option>
                    <option value="TX">Texas</option>
                    <option value="UT">Utah</option>
                    <option value="VT">Vermont</option>
                    <option value="VA">Virginia</option>
                    <option value="WA">Washington</option>
                    <option value="WV">West Virginia</option>
                    <option value="WI">Wisconsin</option>
                    <option value="WY">Wyoming</option>
                </select>
                </div>
            </div>
            <div class="element-container-row-space-between">
                <div class="element-container-col-start-center">
                <label class="capitalize" for="city-admin-create-page"> city </label>
                <input
                    id="city-admin-create-page"
                    class="bold"
                    type="text"
                    name="city"
                />
                </div>
                <div class="element-container-col-start-center">
                <label class="capitalize" for="zip-code-admin-create-page"> zip </label>
                <input
                    id="zip-code-admin-create-page"
                    class="bold"
                    type="text"
                    name="zip_code"
                />
                </div>
            </div>
            <div class="element-container-row-space-between">
                <div class="element-container-col-start-center">
                <label for="avatar-type-admin-create-page"> avatar </label>
                <input
                    id="avatar-type-admin-create-page"
                    class="emoji lowercase bold"
                    type="text"
                    name="avatar_type"
                />
                </div>
                <div class="element-container-col-start-center">
                <label for="avatar-color-fg-admin-create-page"> colorFG </label>
                <input
                    id="avatar-color-fg-admin-create-page"
                    class="lowercase bold"
                    type="text"
                    name="avatar_color_fg"
                />
                </div>
                <div class="element-container-col-start-center">
                <label for="avatar-color-bg-top-admin-create-page"> colorBG↑ </label>
                <input
                    id="avatar-color-bg-top-admin-create-page"
                    class="lowercase bold"
                    type="text"
                    name="avatar_color_bg_top"
                />
                </div>
                <div class="element-container-col-start-center">
                <label for="avatar-color-bg-bottom-admin-create-page"> colorBG↓ </label>
                <input
                    id="avatar-color-bg-bottom-admin-create-page"
                    class="lowercase bold"
                    type="text"
                    name="avatar_color_bg_bottom"
                />
                </div>
            </div>
            <label class="capitalize" for="notes-admin-create-page"> notes </label>
            <textarea
                id="notes-admin-create-page"
                class="bold"
                name="notes"
            ></textarea>
            <div class="button-container-col">
              <a class="fake-button wide-button" href="/app/admin">cancel changes</a>
              <button class="wide-button" type="submit">submit profile changes</button>
            </div>
        </form>
      </div>
    </main>
    <%- include('./partials/footer.ejs') %>
  </body>
</html>
